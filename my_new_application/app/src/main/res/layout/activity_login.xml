<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="28dp">

        <!-- Logo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚗"
            android:textSize="72sp"
            android:layout_marginTop="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Covoiturage Urbain"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:textColor="#10b981"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"/>

        <!-- ══════ CHOIX DE RÔLE ══════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Je suis..."
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="28dp">

            <!-- Conducteur (sélectionné par défaut) -->
            <LinearLayout
                android:id="@+id/btnChoixDriver"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/role_bg_selected"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🚗"
                    android:textSize="30sp"/>

                <TextView
                    android:id="@+id/tvDriverLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Conducteur"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- Passager -->
            <LinearLayout
                android:id="@+id/btnChoixPassenger"
                android:layout_width="0dp"
                android:layout_height="90dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/role_bg_unselected"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="30sp"/>

                <TextView
                    android:id="@+id/tvPassengerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Passager"
                    android:textColor="#64748B"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ══════ FORMULAIRE ══════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_dark"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Email"
                android:textColor="#CBD5E1"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="18dp"
                android:background="@drawable/input_dark_bg"
                android:hint="votre@email.com"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Mot de passe"
                android:textColor="#CBD5E1"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/input_dark_bg"
                android:hint="••••••••"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#FFFFFF"/>

            <!-- Erreur -->
            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#7F1D1D"
                android:padding="12dp"
                android:text=""
                android:textColor="#F87171"
                android:textSize="13sp"
                android:visibility="gone"/>

            <!-- Bouton Se connecter -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:backgroundTint="#6C63FF"
                android:text="Se connecter"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- ✅ NOUVEAU — Bouton S'inscrire -->
            <Button
                android:id="@+id/btnGoRegister"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Pas de compte ? S'inscrire"
                android:textColor="#A5B4FC"
                android:textSize="14sp"
                android:backgroundTint="#1E293B"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Covoiturage Urbain "
            android:textColor="#2196F3"
            android:textSize="11sp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>